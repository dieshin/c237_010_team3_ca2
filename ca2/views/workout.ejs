<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Workouts</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

<nav class="navbar navbar-expand-sm bg-dark navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="/dashboard">Gym Workout Tracker</a>

        <div class="navbar-nav">
            <a class="nav-link" href="/dashboard">Dashboard</a>
            <a class="nav-link" href="/workout/add">Add Workout</a>
            <a class="nav-link" href="/logout">Logout</a>
        </div>
    </div>
</nav>

<div class="container mt-4">

    <h2 class="text-center mb-4">My Workouts</h2>

    <!-- SEARCH, FILTER AND SORT FORM -->
    <form action="/workout" method="GET" class="card p-3 mb-4">

        <div class="row g-3">

            <div class="col-md-4">
                <label class="form-label">Search Exercise</label>

                <input
                    type="text"
                    name="search"
                    class="form-control"
                    placeholder="Search exercise or title"
                    value="<%= search || '' %>"
                >
            </div>

            <div class="col-md-4">
                <label class="form-label">Muscle Group</label>

                <select name="muscleGroup" class="form-select">

                    <option value="">All Muscle Groups</option>

                    <option value="Chest" <%= muscleGroup === 'Chest' ? 'selected' : '' %>>
                        Chest
                    </option>

                    <option value="Back" <%= muscleGroup === 'Back' ? 'selected' : '' %>>
                        Back
                    </option>

                    <option value="Legs" <%= muscleGroup === 'Legs' ? 'selected' : '' %>>
                        Legs
                    </option>

                    <option value="Shoulders" <%= muscleGroup === 'Shoulders' ? 'selected' : '' %>>
                        Shoulders
                    </option>

                    <option value="Arms" <%= muscleGroup === 'Arms' ? 'selected' : '' %>>
                        Arms
                    </option>

                    <option value="Abs" <%= muscleGroup === 'Abs' ? 'selected' : '' %>>
                        Abs
                    </option>

                </select>
            </div>

            <div class="col-md-4">
                <label class="form-label">Organise By</label>

                <select name="sort" class="form-select">

                    <option value="newest" <%= sort === 'newest' ? 'selected' : '' %>>
                        Newest First
                    </option>

                    <option value="oldest" <%= sort === 'oldest' ? 'selected' : '' %>>
                        Oldest First
                    </option>

                    <option value="heaviest" <%= sort === 'heaviest' ? 'selected' : '' %>>
                        Heaviest Weight
                    </option>

                </select>
            </div>

        </div>

        <div class="mt-3">

            <button type="submit" class="btn btn-primary">
                Search / Filter
            </button>

            <a href="/workout" class="btn btn-secondary">
                Clear
            </a>

        </div>

    </form>

    <!-- WORKOUT RESULTS -->

    <% if (workouts.length === 0) { %>

        <div class="alert alert-info">
            No workouts found.
        </div>

    <% } else { %>

        <div class="row">

            <% workouts.forEach(workout => { %>

                <div class="col-md-6 mb-4">

                    <div class="card shadow">

                        <div class="card-body">

                            <h4 class="card-title">
                                <%= workout.title %>
                            </h4>

                            <hr>

                            <p>
                                <strong>Exercise:</strong>
                                <%= workout.exerciseName %>
                            </p>

                            <p>
                                <strong>Muscle Group:</strong>
                                <%= workout.muscleGroup %>
                            </p>

                            <p>
                                <strong>Sets:</strong>
                                <%= workout.sets %>
                            </p>

                            <p>
                                <strong>Reps:</strong>
                                <%= workout.reps %>
                            </p>

                            <p>
                                <strong>Weight:</strong>
                                <%= workout.weight %> kg
                            </p>

                            <p>
                                <strong>Rest Time:</strong>
                                <%= workout.restTime %> seconds
                            </p>

                            <p>
                                <strong>Date:</strong>
                                <%= new Date(workout.workoutDate).toLocaleDateString() %>
                            </p>

                            <% if (workout.notes) { %>

                                <p>
                                    <strong>Notes:</strong>
                                    <%= workout.notes %>
                                </p>

                            <% } %>

                            <form
                                action="/workout/delete/<%= workout.workoutId %>"
                                method="POST"
                                onsubmit="return confirm('Are you sure you want to delete this workout?');"
                            >

                                <button type="submit" class="btn btn-danger">
                                    Delete
                                </button>

                            </form>

                        </div>

                    </div>

                </div>

            <% }); %>

        </div>

    <% } %>

</div>

</body>
</html>
