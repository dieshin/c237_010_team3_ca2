<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>My Workouts</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

    <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">
                Gym Workout Tracker
            </a>
            <div class="navbar-nav">
                <a class="nav-link" href="/workout">
                    My Workouts
                </a>
                <a class="nav-link" href="/logout">
                    Logout
                </a>
            </div>
        </div>
    </nav>

    <div class="container mt-5">

        <h2 class="mb-4">
            My Workouts
        </h2>

        <% if (workouts.length === 0) { %>
            <div class="alert alert-info">
                You have not recorded any workouts yet.
            </div>
        <% } else { %>
            <div class="row">
                <% workouts.forEach(workout => { %>
                    <div class="col-md-4 mb-4">
                        <div class="card shadow h-100">
                            <div class="card-body d-flex flex-column justify-content-between">
                                <div>
                                    <h5 class="card-title">
                                        <%= workout.exerciseName %>
                                    </h5>

                                    <p class="card-text">
                                        <strong>Muscle Group:</strong> <%= workout.muscleGroup %><br>
                                        <strong>Sets:</strong> <%= workout.sets %><br>
                                        <strong>Reps:</strong> <%= workout.reps %><br>
                                        <strong>Weight:</strong> <%= workout.weight %> kg<br>
                                        <strong>Date:</strong> <%= new Date(workout.workoutDate).toLocaleDateString('en-GB') %>
                                    </p>

                                    <% if (workout.notes) { %>
                                        <p>
                                            <strong>Notes:</strong> <%= workout.notes %>
                                        </p>
                                    <% } %>
                                </div>

                                <div class="mt-3 pt-3 border-top">
                                    <form action="/workout/delete/<%= workout.id %>" method="POST" onsubmit="return confirm('Are you sure you want to permanently delete this workout?');">
                                        <button type="submit" class="btn btn-danger btn-sm w-100">
                                            Delete Workout
                                        </button>
                                    </form>
                                </div>

                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>

    </div>

</body>

</html>
