<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Log Workout - Gym Tracker</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 40px; background-color: #f4f7f6; }
        .form-container { background: white; padding: 20px; border-radius: 8px; max-width: 550px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        .form-group { margin-bottom: 15px; }
        label { display: block; margin-bottom: 5px; font-weight: bold; }
        input, select { width: 100%; padding: 8px; box-sizing: border-box; border: 1px solid #ccc; border-radius: 4px; }
        button { background-color: #28a745; color: white; padding: 10px 15px; border: none; border-radius: 4px; cursor: pointer; width: 100%; font-size: 16px; }
        button:hover { background-color: #218838; }
        .alert { padding: 10px; margin-bottom: 15px; border-radius: 4px; }
        .alert-danger { background-color: #f8d7da; color: #721c24; }
        .alert-success { background-color: #d4edda; color: #155724; }
    </style>
</head>
<body>

<div class="form-container">
    <h2>Track New Workout Session</h2>
    <p>Welcome back, <strong><%= user.username %></strong>!</p>

    <!-- Error Alerts -->
<% if (typeof errors !== 'undefined' && errors && errors.length > 0) { %>
    <div class="alert alert-danger"><%= errors %></div>
<% } %>
    <!-- Success Alerts -->

<% if (typeof success !== 'undefined' && success && success.length > 0) { %>
    <div class="alert alert-success"><%= success %></div>
<% } %>
    <form action="/workout/add" method="POST">
        <div class="form-group">
            <label>Workout Session Title:</label>
            <input type="text" name="title" placeholder="e.g., Heavy Push Day, Morning Routine">
        </div>

        <div class="form-group">
            <label>Target Muscle Group:</label>
            <select name="muscleGroup">
                <option value="">-- Select Muscle Group --</option>
                <option value="Chest">Chest</option>
                <option value="Back">Back</option>
                <option value="Legs">Legs</option>
                <option value="Shoulders">Shoulders</option>
                <option value="Arms">Arms</option>
                <option value="Core">Core</option>
            </select>
        </div>

        <div class="form-group">
            <label>Exercise Name:</label>
            <input type="text" name="exerciseName" placeholder="e.g., Bench Press, Barbell Squats">
        </div>

        <div class="form-group" style="display: flex; gap: 10px;">
            <div style="flex: 1;">
                <label>Sets:</label>
                <input type="number" name="sets" min="1" placeholder="4">
            </div>
            <div style="flex: 1;">
                <label>Reps:</label>
                <input type="number" name="reps" min="1" placeholder="12">
            </div>
            <div style="flex: 1;">
                <label>Weight (kg):</label>
                <input type="number" step="0.5" name="weight" min="0" placeholder="60" required>
            </div>
        </div>

        <!-- Added Rest Time Field -->
        <div class="form-group">
            <label>Rest Time (seconds or format):</label>
            <input type="text" name="restTime" placeholder="e.g., 60s, 2 mins">
        </div>
       <div class="form-group">
            <label>Notes (Optional):</label>
            <input type="text" name="notes" placeholder="e.g., Felt strong today, good form">
        </div>

        <button type="submit">Log Session</button>
    </form>

    <br>
    <a href="/dashboard">Back to Dashboard</a>
</div>

</body>
</html>