<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body class="bg-light">

    <% if (typeof globalAnnouncement !== 'undefined' && globalAnnouncement) { %>
        <div class="alert alert-warning text-center m-0 rounded-0 border-0 fw-bold shadow-sm" role="alert">
             <%= globalAnnouncement %>
        </div>
    <% } %>

<nav class="navbar navbar-expand-lg navbar-dark bg-primary mb-4 shadow-sm">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/dashboard">💪 Gym Tracker</a>

        <div>
            <% if (user && user.role && user.role.toLowerCase().trim() === 'admin') { %>
                <a href="/admin" class="btn btn-danger me-2 fw-bold"> Admin Dashboard</a>
            <% } %>

            <% if (user && (user.role === 'member' || user.role === 'admin')) { %>
                <span class="badge bg-warning text-dark me-2 fs-6">Member</span>
                <a href="/workout/analytics" class="btn btn-outline-warning me-2">Member Analytics</a>
            <% } else { %>
                <a href="/upgrade" class="btn btn-warning text-dark me-2 fw-bold">Upgrade to Member</a>
            <% } %>

            <a href="/account" class="btn btn-outline-light me-2">My Profile</a>
<a href="/workout" class="btn btn-outline-light me-2">View Workouts</a>
<a href="/workout/add" class="btn btn-success me-2">+ Log Workout</a>
<a href="/logout" class="btn btn-danger">Logout</a>
        </div>
    </div>
</nav>

    <div class="container">

        <div class="card shadow-sm border-0 p-4 mb-4">
            <h2>
                Welcome back, <span class="text-primary"><%= user.username %></span>!
            </h2>
            <p class="text-muted mt-2">
                Track your workouts, monitor your progress and improve your personal bests.
            </p>
            <div class="mt-3">
                <a href="/workout/add" class="btn btn-primary btn-lg me-2">Log New Workout</a>
                <a href="/workout" class="btn btn-secondary btn-lg">View Saved Workouts</a>
            </div>
        </div>

        <div class="row mb-4">

            <div class="col-md-4 mb-3">
                <div class="card shadow border-0 text-center h-100">
                    <div class="card-body">
                        <h5 class="card-title">🔥 Workout Streak</h5>
                        <h1 class="display-4 text-danger"><%= streak %></h1>
                        <p class="text-muted">consecutive workout days</p>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-3">
                <div class="card shadow border-0 text-center h-100">
                    <div class="card-body">
                        <h5 class="card-title">📅 Weekly Progress</h5>
                        <h1 class="display-4 text-primary">
                            <%= weeklyProgress.reduce((total, workout) => total + Number(workout.workoutCount), 0) %>
                        </h1>
                        <p class="text-muted">workouts in the past 7 days</p>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-3">
                <div class="card shadow border-0 text-center h-100">
                    <div class="card-body">
                        <h5 class="card-title">🏆 Personal Bests</h5>
                        <h1 class="display-4 text-success"><%= personalBests.length %></h1>
                        <p class="text-muted">exercises with recorded PRs</p>
                    </div>
                </div>
            </div>

        </div>

        <div class="card shadow border-0 mb-4">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">📊 Weekly Workout Progress</h4>
            </div>
            <div class="card-body">
                <canvas id="weeklyChart"></canvas>
            </div>
        </div>

        <div class="card shadow border-0 mb-5">
            <div class="card-header bg-success text-white">
                <h4 class="mb-0">🏆 Personal Best Tracker</h4>
            </div>
            <div class="card-body">
                <% if (personalBests.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead>
                                <tr>
                                    <th>Exercise</th>
                                    <th>Personal Best Weight</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% personalBests.forEach(function(best) { %>
                                    <tr>
                                        <td><%= best.exerciseName %></td>
                                        <td><strong class="text-success"><%= best.personalBest %> kg</strong></td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <p class="text-muted">No personal bests recorded yet. Start logging workouts to track your progress!</p>
                <% } %>
            </div>
        </div>

    </div>

    <script>
        const weeklyData = <%- JSON.stringify(weeklyProgress) %>;
        const days = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'];

        const workoutCounts = days.map(function(day) {
            const result = weeklyData.find(function(item) {
                return item.day === day;
            });
            return result ? Number(result.workoutCount) : 0;
        });

        new Chart(document.getElementById('weeklyChart'), {
            type: 'bar',
            data: {
                labels: days,
                datasets: [{
                    label: 'Number of Workouts',
                    data: workoutCounts,
                    backgroundColor: 'rgba(13, 110, 253, 0.7)',
                    borderColor: 'rgba(13, 110, 253, 1)',
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: { stepSize: 1 }
                    }
                }
            }
        });
    </script>
</body>
</html>
