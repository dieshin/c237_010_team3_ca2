<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Dashboard</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <!-- Top Navigation Bar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary mb-4">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/dashboard">💪 Gym Tracker</a>
            <div>
                <a href="/workout" class="btn btn-outline-light me-2">View Workouts</a>
                <a href="/workout/add" class="btn btn-success me-2">+ Log Workout</a>
                <a href="/logout" class="btn btn-danger">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container">
        <div class="card shadow-sm border-0 p-4">
            <h2>Welcome back, <span class="text-primary"><%= user.username %></span>!</h2>
            <p class="text-muted mt-2">Use the menu above to manage your workouts or log a new training session.</p>
            
            <div class="mt-3">
                <a href="/workout/add" class="btn btn-primary btn-lg me-2">Log New Workout</a>
                <a href="/workout" class="btn btn-secondary btn-lg">View Saved Workouts</a>
            </div>
        </div>
    </div>

</body>
</html>
