<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Workout</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

<nav class="navbar navbar-expand-sm bg-dark navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="/dashboard">Gym Workout Tracker</a>
        <div class="navbar-nav">
            <a class="nav-link" href="/dashboard">Dashboard</a>
            <a class="nav-link" href="/workout">My Workouts</a>
            <a class="nav-link" href="/edit">Edit Profile</a>
            <a class="nav-link" href="/logout">Logout</a>
        </div>
    </div>
</nav>

<div class="container mt-4">

    <h2 class="mb-4">Edit Workout</h2>

    <% if (errors && errors.length > 0) { %>
        <div class="alert alert-danger">
            <% errors.forEach(function(msg) { %>
                <p class="mb-0"><%= msg %></p>
            <% }); %>
        </div>
    <% } %>

    <form action="/workout/edit/<%= workout.workoutId %>" method="POST" class="card p-4 shadow">

        <div class="mb-3">
            <label class="form-label">Title</label>
            <input type="text" name="title" class="form-control" value="<%= workout.title %>" required>
        </div>

        <div class="mb-3">
            <label class="form-label">Muscle Group</label>
            <select name="muscleGroup" class="form-select" required>
                <option value="Chest" <%= workout.muscleGroup === 'Chest' ? 'selected' : '' %>>Chest</option>
                <option value="Back" <%= workout.muscleGroup === 'Back' ? 'selected' : '' %>>Back</option>
                <option value="Legs" <%= workout.muscleGroup === 'Legs' ? 'selected' : '' %>>Legs</option>
                <option value="Shoulders" <%= workout.muscleGroup === 'Shoulders' ? 'selected' : '' %>>Shoulders</option>
                <option value="Arms" <%= workout.muscleGroup === 'Arms' ? 'selected' : '' %>>Arms</option>
                <option value="Abs" <%= workout.muscleGroup === 'Abs' ? 'selected' : '' %>>Abs</option>
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Exercise Name</label>
            <input type="text" name="exerciseName" class="form-control" value="<%= workout.exerciseName %>" required>
        </div>

        <div class="row">
            <div class="col-md-4 mb-3">
                <label class="form-label">Sets</label>
                <input type="number" name="sets" class="form-control" value="<%= workout.sets %>" required>
            </div>
            <div class="col-md-4 mb-3">
                <label class="form-label">Reps</label>
                <input type="number" name="reps" class="form-control" value="<%= workout.reps %>" required>
            </div>
            <div class="col-md-4 mb-3">
                <label class="form-label">Weight (kg)</label>
                <input type="number" name="weight" class="form-control" value="<%= workout.weight %>" required>
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label">Rest Time (seconds)</label>
            <input type="text" name="restTime" class="form-control" value="<%= workout.restTime %>" required>
        </div>

        <div class="mb-3">
            <label class="form-label">Notes</label>
            <textarea name="notes" class="form-control"><%= workout.notes || '' %></textarea>
        </div>

        <button type="submit" class="btn btn-primary">Save Changes</button>
        <a href="/workout" class="btn btn-secondary">Cancel</a>

    </form>

</div>

</body>
</html>
