<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Member Analytics</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-warning mb-4 shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold text-dark" href="/dashboard">Member Analytics Page</a>
            <div>
                <a href="/dashboard" class="btn btn-outline-dark btn-sm me-2">Back to Dashboard</a>
                <a href="/logout" class="btn btn-danger btn-sm">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container mb-5">
        <div class="card shadow-sm border-0 p-4 mb-4">
            <h2>Exclusive Member Insights</h2>
            <p class="text-muted">Welcome, <strong><%= (typeof user !== 'undefined' && user) ? user.username : 'Member' %></strong>! Here you get access to advanced features.</p>
        </div>

        <div class="row">
            <div class="col-md-6 mb-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-header bg-primary text-white fw-bold">Strength Progression Insights</div>
                    <div class="card-body text-center py-5">
                        <h5 class="text-muted">Estimated 1-Rep Max (1RM)</h5>
                        <h1 class="display-3 text-primary fw-bold"><%= max1RM ? max1RM + ' kg' : 'N/A' %></h1>
                        <% if (typeof monthIncrease !== 'undefined' && monthIncrease !== null) { %>
                            <p class="text-success mb-0">▲ <%= monthIncrease %>% increase compared to last month</p>
                        <% } else { %>
                            <p class="text-muted mb-0">Log more workouts to see monthly growth!</p>
                        <% } %>
                    </div>
                </div>
            </div>

            <div class="col-md-6 mb-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-header bg-success text-white fw-bold">Target Muscle Distribution</div>
                    <div class="card-body">
                        <% if (typeof muscleDistribution !== 'undefined' && muscleDistribution.length > 0) { %>
                            <% 
                                const colors = ['bg-primary', 'bg-success', 'bg-warning', 'bg-info', 'bg-danger'];
                                muscleDistribution.forEach(function(item, index) { 
                                    const barColor = colors[index % colors.length];
                            %>
                                <p class="mb-1">
                                    <strong><%= item.category %></strong> 
                                    <span class="float-end"><%= item.percentage %>%</span>
                                </p>
                                <div class="progress mb-3" style="height: 10px;">
                                    <div class="progress-bar <%= barColor %>" style="width: <%= item.percentage %>%"></div>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <p class="text-muted text-center py-4">No workout data logged yet to calculate muscle split.</p>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>