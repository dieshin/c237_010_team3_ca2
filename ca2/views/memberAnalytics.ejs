<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>VIP Member Analytics</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-warning mb-4 shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold text-dark" href="/dashboard">Member Analytics Page</a>
            <div>
                <a href="/dashboard" class="btn btn-outline-dark btn-sm me-2">Back to Dashboard</a>
                <a href="/logout" class="btn btn-danger btn-sm">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container mb-5">
        <div class="card shadow-sm border-0 p-4 mb-4">
            <h2>Exclusive Member Insights</h2>
            <p class="text-muted">Welcome,member! Here you get access to advanced features</p>
        </div>

        <div class="row">
            <div class="col-md-6 mb-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-header bg-primary text-white fw-bold">Strength Progression Insights</div>
                    <div class="card-body text-center py-5">
                        <h5 class="text-muted">Estimated 1-Rep Max (1RM)</h5>
                        <h1 class="display-3 text-primary fw-bold">120 kg</h1>
                        <p class="text-success mb-0">▲ 8% increase compared to last month</p>
                    </div>
                </div>
            </div>

            <div class="col-md-6 mb-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-header bg-success text-white fw-bold">Target Muscle Distribution</div>
                    <div class="card-body">
                        <p class="mb-1"><strong>Chest & Triceps</strong> <span class="float-end">40%</span></p>
                        <div class="progress mb-3" style="height: 10px;">
                            <div class="progress-bar bg-primary" style="width: 40%"></div>
                        </div>

                        <p class="mb-1"><strong>Back & Biceps</strong> <span class="float-end">35%</span></p>
                        <div class="progress mb-3" style="height: 10px;">
                            <div class="progress-bar bg-success" style="width: 35%"></div>
                        </div>

                        <p class="mb-1"><strong>Legs & Core</strong> <span class="float-end">25%</span></p>
                        <div class="progress mb-3" style="height: 10px;">
                            <div class="progress-bar bg-warning" style="width: 25%"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>