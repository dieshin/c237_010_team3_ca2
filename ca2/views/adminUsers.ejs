<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - User Management</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-danger mb-4 shadow-sm">
        <div class="container">
            <span class="navbar-brand fw-bold"> Admin Dashboard</span>
            <div class="navbar-nav me-auto">
                <a class="nav-link text-white" href="/admin">Overview & Logs</a>
                <a class="nav-link active fw-bold" href="/admin/users">User Management</a>
            </div>
            <div>
                <a href="/dashboard" class="btn btn-outline-light btn-sm me-2">User View</a>
                <a href="/logout" class="btn btn-light text-danger btn-sm fw-bold">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container mb-5">
        <% if (typeof messages !== 'undefined' && messages && messages.length > 0) { %>
            <div class="alert alert-success shadow-sm mb-4"><%= messages %></div>
        <% } %>

        <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
            <div class="alert alert-danger shadow-sm mb-4"><%= error %></div>
        <% } %>

        <div class="card shadow-sm border-0">
            <div class="card-header bg-white fw-bold py-3"> Manage User Accounts</div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th>Username</th>
                                <th>Email</th>
                                <th>Role</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (typeof allUsers !== 'undefined' && allUsers.length > 0) { %>
                                <% allUsers.forEach(function(u) { %>
                                    <tr>
                                        <td><%= u.id || u.userId %></td>
                                        <td><strong><%= u.username %></strong></td>
                                        <td><%= u.email %></td>
                                        <td>
                                            <span class="badge <%= u.role === 'admin' ? 'bg-danger' : (u.role === 'member' ? 'bg-warning text-dark' : 'bg-secondary') %>">
                                                <%= u.role %>
                                            </span>
                                        </td>
                                        <td>
                                            <% if (u.status === 'banned') { %>
                                                <span class="badge bg-danger">Banned</span>
                                            <% } else if (u.status === 'locked' || u.login_attempts >= 3) { %>
                                                <span class="badge bg-warning text-dark">Locked</span>
                                            <% } else { %>
                                                <span class="badge bg-success">Active</span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <% if (u.status === 'locked' || u.login_attempts >= 3) { %>
                                                <form action="/admin/unlock/<%= u.id || u.userId %>" method="POST" class="d-inline">
                                                    <button type="submit" class="btn btn-warning btn-sm me-1">Unlock</button>
                                                </form>
                                            <% } %>

                                            <% if (u.role !== 'admin') { %>
                                                <form action="/admin/ban/<%= u.id || u.userId %>" method="POST" class="d-inline">
                                                    <button type="submit" class="btn btn-<%= u.status === 'banned' ? 'success' : 'danger' %> btn-sm">
                                                        <%= u.status === 'banned' ? 'Unban' : 'Ban' %>
                                                    </button>
                                                </form>
                                            <% } else { %>
                                                <span class="text-muted small">N/A</span>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="6" class="text-center text-muted py-4">No users found.</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

</body>
</html>