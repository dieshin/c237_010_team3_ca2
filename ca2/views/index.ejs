<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Anytime Gym - Welcome</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light d-flex align-items-center min-vh-100">

    <% if (typeof globalAnnouncement !== 'undefined' && globalAnnouncement) { %>
        <div class="alert alert-warning text-center position-fixed top-0 w-100 m-0 rounded-0 border-0 fw-bold shadow-sm z-3" role="alert">
             <%= globalAnnouncement %>
        </div>
    <% } %>

    <div class="container text-center">
        <div class="card shadow-lg border-0 p-5 mx-auto" style="max-width: 600px;">
            <h1 class="display-4 fw-bold text-primary mb-3">💪 Anytime Gym</h1>
            <p class="lead text-muted mb-4">Track your workouts, monitor your personal bests, and hit your fitness goals.</p>
            
            <div class="d-grid gap-3 d-sm-flex justify-content-sm-center">
                <a href="/login" class="btn btn-primary btn-lg px-4 gap-3">Sign In</a>
                <a href="/register" class="btn btn-outline-secondary btn-lg px-4">Get Started</a>
            </div>
        </div>
    </div>

</body>
</html>