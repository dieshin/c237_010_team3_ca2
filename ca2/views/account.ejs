<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Account Profile</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-primary mb-4 shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/dashboard">💪 Anytime Gym</a>
            <div>
                <a href="/dashboard" class="btn btn-outline-light me-2">Dashboard</a>
                <a href="/logout" class="btn btn-danger">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container" style="max-width: 600px;">
        <% if (typeof messages !== 'undefined' && messages && messages.length > 0) { %>
            <div class="alert alert-success shadow-sm mb-4"><%= messages %></div>
        <% } %>

        <div class="card shadow border-0 p-4">
            <h3 class="mb-3 text-primary fw-bold">Account Profile</h3>
            <hr>
            
            <div class="mb-3">
                <label class="text-muted small d-block">Username</label>
                <span class="fs-5 fw-semibold"><%= profile.username %></span>
            </div>

            <div class="mb-3">
                <label class="text-muted small d-block">Email Address</label>
                <span class="fs-5 fw-semibold"><%= profile.email %></span>
            </div>

            <div class="mb-3">
                <label class="text-muted small d-block">Contact</label>
                <span class="fs-5 fw-semibold"><%= profile.contact %></span>
            </div>

            <div class="mb-3">
                <label class="text-muted small d-block">Address</label>
                <span class="fs-5 fw-semibold"><%= profile.address %></span>
            </div>

            <div class="mb-4">
                <label class="text-muted small d-block">Account Role</label>
                <span class="badge bg-secondary fs-6"><%= profile.role.toUpperCase() %></span>
            </div>

            <a href="/edit" class="btn btn-warning fw-bold w-100"> Edit Profile</a>
        </div>
    </div>
</body>
</html>
