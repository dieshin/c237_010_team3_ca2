<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Admin - Overview & Logs</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-danger mb-4 shadow-sm">
        <div class="container">
            <span class="navbar-brand fw-bold"> Admin Portal</span>
            <div class="navbar-nav me-auto">
                <a class="nav-link active fw-bold" href="/admin">Overview & Logs</a>
                <a class="nav-link text-white" href="/admin/users">User Management</a>
            </div>
            <div>
                <a href="/dashboard" class="btn btn-outline-light btn-sm me-2">User View</a>
                <a href="/logout" class="btn btn-light text-danger btn-sm fw-bold">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container mb-5">
        <% if (typeof messages !== 'undefined' && messages && messages.length > 0) { %>
            <div class="alert alert-success shadow-sm mb-4"><%= messages %></div>
        <% } %>

        <h3 class="mb-3">System Analytics</h3>
        <div class="row mb-4">
            <div class="col-md-6 mb-3">
                <div class="card shadow-sm border-0 text-center p-3">
                    <h6 class="text-muted">Total Registered Users</h6>
                    <h2 class="text-primary"><%= stats.totalUsers %></h2>
                </div>
            </div>
            <div class="col-md-6 mb-3">
                <div class="card shadow-sm border-0 text-center p-3">
                    <h6 class="text-muted">Total Workouts Logged</h6>
                    <h2 class="text-success"><%= stats.totalWorkouts %></h2>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-dark text-white fw-bold">Post Announcements</div>
            <div class="card-body">
                <form action="/admin/announcement" method="POST" class="d-flex gap-2">
                    <input type="text" name="announcement" class="form-control" placeholder="e.g., Gym closed for maintenance..." required>
                    <button type="submit" class="btn btn-warning text-nowrap">Broadcast</button>
                </form>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-header bg-secondary text-white fw-bold">System Logs</div>
            <div class="card-body p-0">
                <ul class="list-group list-group-flush">
                    <% if (typeof logs !== 'undefined' && logs.length > 0) { %>
                        <% logs.forEach(function(log) { %>
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <span><%= log.action %></span>
                                <small class="text-muted"><%= log.timestamp %></small>
                            </li>
                        <% }); %>
                    <% } else { %>
                        <li class="list-group-item text-muted text-center">No logs recorded yet.</li>
                    <% } %>
                </ul>
            </div>
        </div>
    </div>
</body>
</html>