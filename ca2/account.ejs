<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Account Profile</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-primary mb-4">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/dashboard">Gym Tracker</a>
            <div>
                <a href="/dashboard" class="btn btn-outline-light me-2">Dashboard</a>
                <a href="/logout" class="btn btn-danger">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container col-md-6 mt-4">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                <h4 class="mb-0">Profile</h4>
                <span class="badge bg-warning text-dark text-uppercase"><%= profile.role %></span>
            </div>
            <div class="card-body p-4">
                <div class="mb-3">
                    <label class="text-muted small">Username</label>
                    <p class="fs-5 fw-bold mb-0"><%= profile.username %></p>
                </div>
                <hr>
                <div class="mb-3">
                    <label class="text-muted small">Email Address</label>
                    <p class="fs-5 mb-0"><%= profile.email %></p>
                </div>
                <hr>
                <div class="mb-3">
                    <label class="text-muted small">Contact Number</label>
                    <p class="fs-5 mb-0"><%= profile.contact %></p>
                </div>
                <hr>
                <div class="mb-3">
                    <label class="text-muted small">Address</label>
                    <p class="fs-5 mb-0"><%= profile.address %></p>
                </div>
                <hr>
                <div class="mb-3">
                    <label class="text-muted small">Account Status</label>
                    <p class="mb-0"><span class="badge bg-success"><%= profile.status %></span></p>
                </div>

                <div class="mt-4">
                    <a href="/dashboard" class="btn btn-secondary w-100">Back to Dashboard</a>
                </div>
            </div>
        </div>
    </div>

</body>
</html>